# Required only when opt-in failed-source reporting is enabled.
DEOBFUSCATION_REPORT_SECRET=replace-with-at-least-32-random-bytes
CRON_SECRET=replace-with-a-separate-random-secret

# Use a private Vercel Blob store. A connected Vercel project normally injects
# BLOB_READ_WRITE_TOKEN. OIDC deployments use both variables below instead.
BLOB_READ_WRITE_TOKEN=
VERCEL_OIDC_TOKEN=
BLOB_STORE_ID=

# Native worker paths are set by the Docker image or deployment pipeline.
RBX_RUNTIME_BINARY=
ALEXFUSCATOR_BINARY=
ALEX_DEOBFUSCATOR_BINARY=
